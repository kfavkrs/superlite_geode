---
import "../styles/global.css";
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import { navBarLinks, identity, socialLinks } from "../config";
import type { SEOInfo } from "../types/config";

interface Props {
  seo: SEOInfo;
}

const { seo } = Astro.props;
---

<script>
  const navPhoneLink = document.querySelector('header a[href^="tel:"]') as HTMLAnchorElement | null;
  if (navPhoneLink) {
    navPhoneLink.addEventListener('click', (e) => {
      const isMobile = /Android|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent);
      if (!isMobile) {
        e.preventDefault();
        navigator.clipboard.writeText('+1 (415) 335-9911').then(() => {
          const rect = navPhoneLink.getBoundingClientRect();
          const tip = document.createElement('span');
          tip.textContent = 'Copied!';
          tip.style.cssText = `position:fixed;top:${rect.bottom + 6}px;left:${rect.left + rect.width / 2}px;transform:translateX(-50%);background:#333;color:#fff;font-size:12px;padding:3px 8px;border-radius:4px;pointer-events:none;z-index:9999;transition:opacity 0.3s`;
          document.body.appendChild(tip);
          setTimeout(() => { tip.style.opacity = '0'; }, 1500);
          setTimeout(() => { tip.remove(); }, 1800);
        });
      }
    });
  }
</script>

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/superlite_geode/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{seo.title}</title>
    <meta name="description" content={seo.description} />
    <meta property="og:title" content={seo.title} />
    <meta property="og:description" content={seo.description} />
    <meta property="og:image" content={seo.image} />
  </head>
  <body>
    <header class="sticky top-0 z-50 bg-[var(--color-bg)]">
      <div class="px-6 py-4 max-w-3xl mx-auto">

        <!-- Single row: Logo (desktop only) + nav links + social icons (desktop only) -->
        <div class="flex items-center">

          <!-- Logo: desktop only -->
          <a href="/superlite_geode/" class="hidden sm:block shrink-0 mr-6">
            <Image
              src={identity.logo}
              alt={"Logo"}
              width={50}
              height={50}
              class="w-[50px] h-[50px] object-cover rounded-full"
            />
          </a>

          <!-- Nav links: always visible. Mobile: justify-between (fills width). Desktop: justify-end with gap. -->
          <nav class="flex-1">
            <ul class="flex items-center justify-between sm:justify-end sm:gap-4">
              {
                navBarLinks.map((link) => (
                  <li>
                    <a
                      class="block px-2 py-2 text-sm sm:px-4 sm:text-base font-semibold text-[var(--color-text)] rounded-lg hover:bg-gray-100 hover:text-[var(--color-secondary)] transition-all whitespace-nowrap"
                      href={link.url}
                      target={link.external ? "_blank" : "_self"}
                    >
                      {link.title}
                    </a>
                  </li>
                ))
              }
            </ul>
          </nav>

          <!-- Social icons: desktop only -->
          <div class="hidden sm:flex gap-4 ml-4 shrink-0">
            {
              socialLinks.map((link) => (
                <a
                  href={link.url}
                  target={link.external ? "_blank" : "_self"}
                  class="block p-2 opacity-60 hover:opacity-100 transition-opacity"
                  aria-label={link.title}
                >
                  <Icon name={link.icon} width={20} height={20} />
                </a>
              ))
            }
          </div>
        </div>

        <!-- Row 2: Social icons (mobile only), staggered under nav words via justify-around -->
        <div class="flex sm:hidden justify-around pt-1 pb-2">
          {
            socialLinks.map((link) => (
              <a
                href={link.url}
                target={link.external ? "_blank" : "_self"}
                class="block p-2 opacity-60 hover:opacity-100 transition-opacity"
                aria-label={link.title}
              >
                <Icon name={link.icon} width={20} height={20} />
              </a>
            ))
          }
        </div>

      </div>
    </header>
    <main class="mb-32">
      <slot />
    </main>
    <footer></footer>
  </body>
</html>

<style is:global>
  @import url("https://fonts.googleapis.com/css2?family=Josefin+Sans:ital,wght@0,100..700;1,100..700&display=swap");

  html {
    font-family: "Josefin Sans", sans-serif;
    font-size: 18px;
  }

  * {
    -webkit-font-smoothing: antialiased;
  }

  code {
    font-family:
      Menlo,
      Monaco,
      Lucida Console,
      Liberation Mono,
      DejaVu Sans Mono,
      Bitstream Vera Sans Mono,
      Courier New,
      monospace;
  }

  .hover-underline {
    text-decoration: underline 1px rgba(0, 0, 0, 0);
    text-underline-offset: 5px;
    transition: text-decoration-color 300ms;
  }

  .post:hover .hover-underline {
    text-decoration-color: var(--color-text);
  }
</style>
